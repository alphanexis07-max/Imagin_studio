generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model Site {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  collection String
  order      Int      @default(0)
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([collection, order])
}

model Reel {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tag         String
  title       String
  description String
  url         String
  kind        String
  embedUrl    String
  poster      String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model MediaAsset {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  publicId     String   @unique
  url          String
  secureUrl    String
  resourceType String
  format       String?
  width        Int?
  height       Int?
  bytes        Int?
  folder       String?
  createdAt    DateTime @default(now())
}
